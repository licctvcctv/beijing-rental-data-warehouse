FROM eclipse-temurin:8-jdk

WORKDIR /workspace/warehouse

COPY warehouse/src/main/java src/main/java
COPY warehouse/src/main/resources src/main/resources
COPY warehouse/scripts/docker/run_local_offline_entrypoint.sh scripts/docker/run_local_offline_entrypoint.sh

RUN mkdir -p target/local-classes \
    && javac -encoding UTF-8 \
       -sourcepath src/main/java \
       -d target/local-classes \
       src/main/java/com/beijing/wenyu/runner/LocalOfflineWarehouseRunner.java \
       src/main/java/com/beijing/wenyu/runner/MetabaseBootstrapRunner.java \
    && chmod +x scripts/docker/run_local_offline_entrypoint.sh

ENTRYPOINT ["sh", "scripts/docker/run_local_offline_entrypoint.sh"]
